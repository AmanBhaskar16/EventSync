
generator client {
  provider = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum Role {
  CUSTOMER
  VENDOR
  ADMIN
}

enum KYCStatus {
  PENDING
  UNDER_REVIEW
  APPROVED
  REJECTED
}

enum VendorCategory {
  CATERING
  DECOR
  PHOTOGRAPHY
  VIDEOGRAPHY
  VENUE
  ENTERTAINMENT
  DJ_MUSIC
  TRANSPORTATION
  FLORALS
  MAKEUP_ARTIST
  MEHENDI
  SOUND_LIGHTING
  INVITATION_DESIGN
  CAKE_BAKERY
  SECURITY
  ANCHOR_HOST
  OTHER
}

enum EventType {
  WEDDING
  BIRTHDAY
  BACHELORETTE
  BACHELOR
  ANNIVERSARY
  CORPORATE
  KITTY_PARTY
  REUNION
  BABY_SHOWER
  ENGAGEMENT
  COCKTAIL_PARTY
  OTHER
}

enum EventStatus {
  DRAFT
  PLANNING
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum BookingStatus {
  INQUIRY
  QUOTE_SENT
  NEGOTIATION
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  DISPUTED
}

enum PaymentStatus {
  PENDING
  PROCESSING
  PAID
  FAILED
  REFUNDED
}

enum PaymentMilestone {
  BOOKING_CONFIRMATION
  PRE_EVENT
  POST_EVENT
}

enum DisputeStatus {
  OPEN
  UNDER_REVIEW
  RESOLVED_CUSTOMER
  RESOLVED_VENDOR
  CLOSED
}

enum QuoteStatus {
  DRAFT
  SENT
  COUNTER_OFFERED
  ACCEPTED
  REJECTED
  EXPIRED
}

// ─────────────────────────────────────────────
// MODELS
// ─────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  name          String?
  phone         String?
  avatar        String?
  role          Role      @default(CUSTOMER)
  passwordHash  String?
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  customer Customer?
  vendor   Vendor?
  admin    Admin?

  @@map("users")
}

model Customer {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  address   String?
  city      String?
  state     String?
  pincode   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  events Event[]

  @@map("customers")
}

model Vendor {
  id               String         @id @default(cuid())
  userId           String         @unique
  user             User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  businessName     String
  category         VendorCategory @default(OTHER)
  description      String?
  gstin            String?
  pan              String?
  businessRegNo    String?
  city             String         @default("")
  state            String         @default("")
  pincode          String         @default("")
  serviceRadius    Int            @default(50)
  kycStatus        KYCStatus      @default(PENDING)
  kycRejectionNote String?
  isVerified       Boolean        @default(false)
  isActive         Boolean        @default(true)
  commissionRate   Float          @default(12.0)
  tier             String         @default("STANDARD")
  avgRating        Float          @default(0)
  totalReviews     Int            @default(0)
  totalBookings    Int            @default(0)
  responseTime     Int            @default(24)
  portfolioImages  String[]       @default([])
  bankAccountNo    String?
  bankIfsc         String?
  bankName         String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  bookings       Booking[]
  inventoryItems InventoryItem[]
  services       VendorService[] 
  reviews        Review[]

  @@map("vendors")
}

model Admin {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  permissions String[] @default([])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("admins")
}

model Event {
  id          String      @id @default(cuid())
  customerId  String
  customer    Customer    @relation(fields: [customerId], references: [id], onDelete: Cascade)
  title       String
  type        EventType   @default(OTHER)
  status      EventStatus @default(DRAFT)
  eventDate   DateTime
  endDate     DateTime?
  venue       String?
  city        String?
  state       String?
  guestCount  Int?
  budget      Float?
  description String?
  isPublic    Boolean     @default(false)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  bookings Booking[]

  @@map("events")
}

model Booking {
  id              String        @id @default(cuid())
  eventId         String
  event           Event         @relation(fields: [eventId], references: [id], onDelete: Cascade)
  vendorId        String
  vendor          Vendor        @relation(fields: [vendorId], references: [id])
  status          BookingStatus @default(INQUIRY)
  agreedPrice     Float?
  platformFee     Float?
  vendorPayout    Float?
  specialRequests String?
  guestCount      Int?
  startTime       DateTime?
  endTime         DateTime?
  confirmedAt     DateTime?
  completedAt     DateTime?
  cancelledAt     DateTime?
  cancelReason    String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  payments Payment[]
  dispute  Dispute?

  quotes   Quote[]
  messages Message[]
  review   Review?

  @@map("bookings")
}

model Payment {
  id                String           @id @default(cuid())
  bookingId         String
  booking           Booking          @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  milestone         PaymentMilestone
  amount            Float
  status            PaymentStatus    @default(PENDING)
  razorpayOrderId   String?
  razorpayPaymentId String?
  paidAt            DateTime?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  @@map("payments")
}

model Dispute {
  id          String        @id @default(cuid())
  bookingId   String        @unique
  booking     Booking       @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  raisedBy    String
  reason      String
  description String        @default("")
  status      DisputeStatus @default(OPEN)
  resolution  String?
  resolvedBy  String?
  resolvedAt  DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@map("disputes")
}

model InventoryItem {
  id             String   @id @default(cuid())
  vendorId       String
  vendor         Vendor   @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  name           String
  description    String?
  totalQuantity  Int      @default(0)
  unit           String   @default("units")
  isReusable     Boolean  @default(true)
  lowStockAlert  Int      @default(5)
  maintenanceQty Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  reservations  InventoryReservation[]

  @@map("inventory_items")
}

model Quote {
  id          String      @id @default(cuid())
  bookingId   String
  booking     Booking     @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  vendorId    String
  status      QuoteStatus @default(DRAFT)
  lineItems   Json        @default("[]")
  subtotal    Float       @default(0)
  gstRate     Float       @default(18)
  gstAmount   Float       @default(0)
  totalAmount Float       @default(0)
  validUntil  DateTime
  notes       String?
  terms       String?
  version     Int         @default(1)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
 
  @@map("quotes")
}
 
model Message {
  id        String   @id @default(cuid())
  bookingId String
  booking   Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  senderId  String
  content   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
 
  @@map("messages")
}

model InventoryReservation {
  id          String        @id @default(cuid())
  itemId      String
  item        InventoryItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  bookingId   String
  quantity    Int
  date        DateTime
  releasedAt  DateTime?
  createdAt   DateTime      @default(now())
 
  @@map("inventory_reservations")
}

model VendorService {
  id          String   @id @default(cuid())
  vendorId    String
  vendor      Vendor   @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  name        String
  description String?
  basePrice   Float
  unit        String   @default("per event")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  serviceAddons ServiceAddon[]

  @@map("vendor_services")
}

model ServiceAddon {
  id        String        @id @default(cuid())
  serviceId String
  service   VendorService @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  name      String
  price     Float
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@map("service_addons")
}

model Review {
  id              String   @id @default(cuid())
  bookingId       String   @unique
  booking         Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  customerId      String
  vendorId        String
  vendor          Vendor   @relation(fields: [vendorId], references: [id])
  reviewerName    String
  punctuality     Int
  quality         Int
  communication   Int
  value           Int
  professionalism Int
  overallRating   Float
  comment         String?
  vendorReply     String?
  isPublic        Boolean  @default(true)
  isFlagged       Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("reviews")
}